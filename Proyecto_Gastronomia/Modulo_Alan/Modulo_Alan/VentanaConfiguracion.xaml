<Window x:Class="Modulo_Alan.Vistas.VentanaConfiguracionVideo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración Avanzada de Video"
        Height="400" 
        Width="500"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="⚙️ Configuración Avanzada de Video" 
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Opciones -->
        <StackPanel Grid.Row="1">
            <GroupBox Header="Configuración de Audio/Video" Margin="0,0,0,15">
                <StackPanel Margin="10">
                    <CheckBox x:Name="chkAudioAutomatico" Content="🎤 Activar audio automáticamente" 
                              IsChecked="True" Margin="0,0,0,10"/>
                    <CheckBox x:Name="chkVideoAutomatico" Content="🎥 Activar video automáticamente" 
                              IsChecked="True" Margin="0,0,0,10"/>
                    <CheckBox x:Name="chkPantallaCompartida" Content="🖥️ Permitir compartir pantalla" 
                              IsChecked="True" Margin="0,0,0,10"/>
                    <CheckBox x:Name="chkSalaEspera" Content="🚪 Habilitar sala de espera" 
                              IsChecked="True"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Calidad y Rendimiento">
                <StackPanel Margin="10">
                    <TextBlock Text="Calidad de Video:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbCalidadVideo" SelectedIndex="1">
                        <ComboBoxItem Content="Baja (320p) - Para conexiones lentas"/>
                        <ComboBoxItem Content="Media (480p) - Balanceado"/>
                        <ComboBoxItem Content="Alta (720p) - Recomendado"/>
                        <ComboBoxItem Content="HD (1080p) - Máxima calidad"/>
                    </ComboBox>

                    <CheckBox x:Name="chkOptimizarAnchoBanda" Content="📶 Optimizar para ancho de banda bajo" 
                              IsChecked="True" Margin="0,10,0,0"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <!-- Botones -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="❌ Cancelar" Click="Cancelar_Click" 
                    Padding="15,8" Margin="0,0,10,0" Width="100"/>
            <Button Content="💾 Aplicar" Click="Aplicar_Click" 
                    Background="#4CAF50" Foreground="White"
                    Padding="15,8" Width="100"/>
        </StackPanel>
    </Grid>
</Window>