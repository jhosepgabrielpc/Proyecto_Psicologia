<Window x:Class="Modulo_Alan.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MindCare - Módulo de Video Conferencias" 
        Height="500" Width="600"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="🎥 Módulo de Video Conferencias - MindCare" 
                  FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Panel de Estado -->
        <Border Grid.Row="1" Background="#F0F8FF" BorderBrush="#BBDEFB" 
                BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15">
            <TextBlock x:Name="txtEstado" Text="Bienvenido al módulo de video conferencias" 
                      FontSize="12" TextWrapping="Wrap"/>
        </Border>

        <!-- Botones de Acción -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="🔍 Probar Conexión Zoom" Click="ProbarConexion_Click" 
                    Padding="15,8" Background="#2196F3" Foreground="White" Margin="0,0,10,0"/>

            <Button Content="⚙️ Configurar Credenciales" Click="Configuracion_Click" 
                    Padding="15,8" Background="#FF9800" Foreground="White" Margin="0,0,10,0"/>

            <Button Content="📋 Ver Credenciales" Click="VerCredenciales_Click" 
                    Padding="15,8" Background="#607D8B" Foreground="White" Margin="0,0,10,0"/>
        </StackPanel>

        <!-- Botones Adicionales -->
        <StackPanel Grid.Row="3" Orientation="Vertical" Margin="0,0,0,20">
            <Button Content="🎥 Abrir Sala de Video (Prueba)" Click="AbrirSalaVideo_Click" 
                    Padding="15,10" Background="#4CAF50" Foreground="White" 
                    FontWeight="Bold" Margin="0,0,0,10"/>

            <Button Content="🌐 Abrir Sala de Pruebas Zoom" Click="AbrirSala_Click" 
                    Padding="15,8" Background="#9C27B0" Foreground="White"/>
        </StackPanel>

        <!-- Footer -->
        <TextBlock Grid.Row="4" Text="MindCare - Plataforma de Teleterapia Professional" 
                  Foreground="Gray" FontSize="10" HorizontalAlignment="Center"/>
    </Grid>
</Window>